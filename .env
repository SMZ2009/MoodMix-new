# MoodMix 环境配置文件

# ═══ LLM 配置 ═══
# SiliconFlow API Key - 用于 mood 分析
# 在 https://docs.siliconflow.cn/ 获取你的 API Key
SILICONFLOW_API_KEY=sk-ejffatyebwkzpezanmyyxlpmqbtupnmfdyqbvbhjjdmlkitw
SILICONFLOW_MODEL_CORE=Pro/deepseek-ai/Janus-Pro-7B
SILICONFLOW_MODEL_CREATIVE=Pro/deepseek-ai/Janus-Pro-7B
# 备注：用户要求的 Qwen3 模型在 SiliconFlow 可能对应特定路径，此处先按命名规范占位，实际由用户 Key 对应的可用路径为准
# 备注：使用 Qwen2.5 系列作为当前最稳定的 Qwen 旗舰版本
# 8B 对应 Qwen2.5-7B/Qwen2-7B，30B 对应 Qwen2.5-32B
SILICONFLOW_MODEL_8B=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_MODEL_30B=Qwen/Qwen2.5-32B-Instruct

# ═══ 服务器配置 ═══
NODE_ENV=development

# 前端应用端口
# PORT=3000  # 生产环境由 Render 平台设置

# API 代理服务器端口
PROXY_PORT=3001

# ═══ Webpack 开发服务器配置（用于 npm start） ═══
# 禁用 Host 头检查，允许本地访问（localhost, 127.0.0.1 以及其他 Host）
# 这允许你从不同的 Host 访问开发服务器
HOST=0.0.0.0

# 为了支持 Render.com 等平台的自动 Host 头验证，可以设置 DANGEROUSLY_DISABLE_HOST_CHECK
# 仅在开发环境中使用！
DANGEROUSLY_DISABLE_HOST_CHECK=true

# ═══ 可选项 ═══
# 公共 URL（如果部署在子路径上）
PUBLIC_URL=/

# 浏览器自动打开（开发用）
BROWSER=none
